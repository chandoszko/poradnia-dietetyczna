---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kontakt">
  <!-- Hero -->
  <section class="bg-granat text-biala py-16">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl font-bold text-center">Kontakt</h1>
    </div>
  </section>

  <!-- Contact -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12">
        <!-- Formularz -->
        <div>
          <h2 class="text-2xl font-bold mb-6 text-granat">Napisz do nas</h2>
          <form class="space-y-6">
            <div>
              <label class="block text-granat font-medium mb-2">Imię i nazwisko</label>
              <input type="text" class="w-full px-4 py-3 border border-mietowy rounded-lg focus:outline-none focus:border-limonka" placeholder="Jan Kowalski">
            </div>
            <div>
              <label class="block text-granat font-medium mb-2">Email</label>
              <input type="email" class="w-full px-4 py-3 border border-mietowy rounded-lg focus:outline-none focus:border-limonka" placeholder="jan@example.com">
            </div>
            <div>
              <label class="block text-granat font-medium mb-2">Telefon</label>
              <input type="tel" class="w-full px-4 py-3 border border-mietowy rounded-lg focus:outline-none focus:border-limonka" placeholder="+48 000 000 000">
            </div>
            <div>
              <label class="block text-granat font-medium mb-2">Wiadomość</label>
              <textarea class="w-full px-4 py-3 border border-mietowy rounded-lg focus:outline-none focus:border-limonka h-32" placeholder="Twoja wiadomość..."></textarea>
            </div>
            <button type="submit" class="w-full bg-limonka text-granat px-6 py-3 rounded-full font-semibold hover:bg-morska-ziel transition-colors">
              Wyślij wiadomość
            </button>
          </form>
        </div>
        
        <!-- Dane kontaktowe -->
        <div>
          <h2 class="text-2xl font-bold mb-6 text-granat">Dane kontaktowe</h2>
          <div class="space-y-6">
            <div class="flex items-start">
              <div class="w-12 h-12 bg-limonka rounded-full flex items-center justify-center mr-4 flex-shrink-0">
                <svg class="w-6 h-6 text-granat" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-granat">Telefon</h3>
                <p class="text-granat/80">+48 000 000 000</p>
              </div>
            </div>
            
            <div class="flex items-start">
              <div class="w-12 h-12 bg-limonka rounded-full flex items-center justify-center mr-4 flex-shrink-0">
                <svg class="w-6 h-6 text-granat" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-granat">Email</h3>
                <p class="text-granat/80">kontakt@poradnia.pl</p>
              </div>
            </div>
            
            <div class="flex items-start">
              <div class="w-12 h-12 bg-limonka rounded-full flex items-center justify-center mr-4 flex-shrink-0">
                <svg class="w-6 h-6 text-granat" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-granat">Adres</h3>
                <p class="text-granat/80">ul. Przykładowa 1</p>
                <p class="text-granat/80">00-000 Warszawa</p>
              </div>
            </div>
            
            <div class="flex items-start">
              <div class="w-12 h-12 bg-limonka rounded-full flex items-center justify-center mr-4 flex-shrink-0">
                <svg class="w-6 h-6 text-granat" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-granat">Godziny otwarcia</h3>
                <p class="text-granat/80">Pon-Pt: 8:00 - 18:00</p>
                <p class="text-granat/80">Sob: 9:00 - 14:00</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mapa -->
  <section class="h-96 bg-mietowy">
    <div class="w-full h-full flex items-center justify-center">
      <span class="text-granat/50 text-lg">[Mapa Google]</span>
    </div>
  </section>
</Layout>