---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Strona nie znaleziona">
  <section class="min-h-screen flex items-center justify-center bg-gradient-to-b from-biala to-mietowy-light pt-[72px]">
    <div class="text-center px-6 max-w-[500px]">
      <div class="text-[6rem] font-heading font-bold text-granat leading-none mb-4">404</div>
      <h1 class="font-heading text-[1.8rem] text-granat mb-3">Strona nie znaleziona</h1>
      <p class="text-text-body mb-8">Coś poszło nie tak — strona, której szukasz, nie istnieje lub została przeniesiona.</p>
      <a href="/" class="btn-primary px-8 py-4 text-[1.05rem]">Wróć do strony głównej</a>
    </div>
  </section>
</Layout>
