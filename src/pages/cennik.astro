---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Cennik">
  <!-- Hero -->
  <section class="bg-granat text-biala py-16">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl font-bold text-center">Cennik</h1>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Cennik 1 -->
        <div class="bg-biala border border-mietowy rounded-2xl p-8 hover:shadow-lg transition-shadow">
          <h3 class="text-xl font-semibold mb-2 text-granat">[Nazwa usługi 1]</h3>
          <p class="text-4xl font-bold text-limonka mb-4">[Cena] zł</p>
          <p class="text-granat/80 mb-6">[Opis co zawiera]</p>
          <ul class="space-y-2 mb-6">
            <li class="flex items-center text-granat/80">
              <svg class="w-5 h-5 text-limonka mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              [Element 1]
            </li>
            <li class="flex items-center text-granat/80">
              <svg class="w-5 h-5 text-limonka mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              [Element 2]
            </li>
            <li class="flex items-center text-granat/80">
              <svg class="w-5 h-5 text-limonka mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              [Element 3]
            </li>
          </ul>
          <a href="/kontakt" class="block text-center bg-limonka text-granat px-6 py-3 rounded-full font-semibold hover:bg-morska-ziel transition-colors">
            Umów wizytę
          </a>
        </div>
        
        <!-- Cennik 2 -->
        <div class="bg-biala border-2 border-limonka rounded-2xl p-8 hover:shadow-lg transition-shadow relative">
          <div class="absolute top-0 left-1/2 transform -translate-x-1/2 -translate-y-1/2 bg-limonka text-granat px-4 py-1 rounded-full text-sm font-semibold">
            Polecane
          </div>
          <h3 class="text-xl font-semibold mb-2 text-granat">[Nazwa usługi 2]</h3>
          <p class="text-4xl font-bold text-limonka mb-4">[Cena] zł</p>
          <p class="text-granat/80 mb-6">[Opis co zawiera]</p>
          <ul class="space-y-2 mb-6">
            <li class="flex items-center text-granat/80">
              <svg class="w-5 h-5 text-limonka mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              [Element 1]
            </li>
            <li class="flex items-center text-granat/80">
              <svg class="w-5 h-5 text-limonka mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              [Element 2]
            </li>
            <li class="flex items-center text-granat/80">
              <svg class="w-5 h-5 text-limonka mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              [Element 3]
            </li>
          </ul>
          <a href="/kontakt" class="block text-center bg-limonka text-granat px-6 py-3 rounded-full font-semibold hover:bg-morska-ziel transition-colors">
            Umów wizytę
          </a>
        </div>
        
        <!-- Cennik 3 -->
        <div class="bg-biala border border-mietowy rounded-2xl p-8 hover:shadow-lg transition-shadow">
          <h3 class="text-xl font-semibold mb-2 text-granat">[Nazwa usługi 3]</h3>
          <p class="text-4xl font-bold text-limonka mb-4">[Cena] zł</p>
          <p class="text-granat/80 mb-6">[Opis co zawiera]</p>
          <ul class="space-y-2 mb-6">
            <li class="flex items-center text-granat/80">
              <svg class="w-5 h-5 text-limonka mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              [Element 1]
            </li>
            <li class="flex items-center text-granat/80">
              <svg class="w-5 h-5 text-limonka mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              [Element 2]
            </li>
            <li class="flex items-center text-granat/80">
              <svg class="w-5 h-5 text-limonka mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              [Element 3]
            </li>
          </ul>
          <a href="/kontakt" class="block text-center bg-limonka text-granat px-6 py-3 rounded-full font-semibold hover:bg-morska-ziel transition-colors">
            Umów wizytę
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Info -->
  <section class="py-16 bg-mietowy/30">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl font-bold mb-4 text-granat">Dodatkowe informacje</h2>
        <p class="text-granat/80 mb-4">
          [Informacje o płatnościach, rabatach, ubezpieczeniach]
        </p>
        <p class="text-granat/80">
          [Informacje o konsultacjach online vs stacjonarnych]
        </p>
      </div>
    </div>
  </section>
</Layout>