---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} | Poradnia Dietetyczna</title>
  <meta name="description" content="Poradnia dietetyczna - profesjonalne konsultacje dietetyczne, indywidualne jadłospisy, zdrowe odżywianie">
</head>
<body class="bg-biala text-granat min-h-screen flex flex-col">
  <!-- Header -->
  <header class="bg-granat text-biala sticky top-0 z-50 shadow-lg">
    <nav class="container mx-auto px-4 py-4">
      <div class="flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="text-2xl font-bold hover:text-limonka transition-colors">
          Poradnia Dietetyczna
        </a>
        
        <!-- Desktop Navigation -->
        <ul class="hidden md:flex space-x-8">
          <li><a href="/" class="hover:text-limonka transition-colors">Strona główna</a></li>
          <li><a href="/o-mnie" class="hover:text-limonka transition-colors">O mnie</a></li>
          <li><a href="/uslugi" class="hover:text-limonka transition-colors">Usługi</a></li>
          <li><a href="/cennik" class="hover:text-limonka transition-colors">Cennik</a></li>
          <li><a href="/kontakt" class="hover:text-limonka transition-colors">Kontakt</a></li>
        </ul>
        
        <!-- CTA Button -->
        <a href="/kontakt" class="hidden md:block bg-limonka text-granat px-6 py-2 rounded-full font-semibold hover:bg-morska-ziel transition-colors">
          Umów wizytę
        </a>
        
        <!-- Mobile Menu Button -->
        <button id="mobile-menu-button" class="md:hidden text-biala">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
      
      <!-- Mobile Navigation -->
      <div id="mobile-menu" class="hidden md:hidden mt-4 pb-4">
        <ul class="flex flex-col space-y-4">
          <li><a href="/" class="block hover:text-limonka transition-colors">Strona główna</a></li>
          <li><a href="/o-mnie" class="block hover:text-limonka transition-colors">O mnie</a></li>
          <li><a href="/uslugi" class="block hover:text-limonka transition-colors">Usługi</a></li>
          <li><a href="/cennik" class="block hover:text-limonka transition-colors">Cennik</a></li>
          <li><a href="/kontakt" class="block hover:text-limonka transition-colors">Kontakt</a></li>
        </ul>
        <a href="/kontakt" class="block mt-4 bg-limonka text-granat px-6 py-2 rounded-full font-semibold text-center hover:bg-morska-ziel transition-colors">
          Umów wizytę
        </a>
      </div>
    </nav>
  </header>

  <!-- Main Content -->
  <main class="flex-grow">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="bg-granat text-biala py-12">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Logo i opis -->
        <div>
          <h3 class="text-2xl font-bold mb-4">Poradnia Dietetyczna</h3>
          <p class="text-mietowy">Profesjonalne konsultacje dietetyczne. Zdrowe odżywianie na co dzień.</p>
        </div>
        
        <!-- Linki -->
        <div>
          <h4 class="text-lg font-semibold mb-4">Nawigacja</h4>
          <ul class="space-y-2">
            <li><a href="/" class="text-mietowy hover:text-limonka transition-colors">Strona główna</a></li>
            <li><a href="/o-mnie" class="text-mietowy hover:text-limonka transition-colors">O mnie</a></li>
            <li><a href="/uslugi" class="text-mietowy hover:text-limonka transition-colors">Usługi</a></li>
            <li><a href="/cennik" class="text-mietowy hover:text-limonka transition-colors">Cennik</a></li>
            <li><a href="/kontakt" class="text-mietowy hover:text-limonka transition-colors">Kontakt</a></li>
          </ul>
        </div>
        
        <!-- Kontakt -->
        <div>
          <h4 class="text-lg font-semibold mb-4">Kontakt</h4>
          <ul class="space-y-2 text-mietowy">
            <li>Telefon: <a href="tel:+48000000000" class="hover:text-limonka transition-colors">+48 000 000 000</a></li>
            <li>Email: <a href="mailto:kontakt@poradnia.pl" class="hover:text-limonka transition-colors">kontakt@poradnia.pl</a></li>
            <li>Adres: ul. Przykładowa 1, 00-000 Warszawa</li>
          </ul>
        </div>
      </div>
      
      <!-- Copyright -->
      <div class="border-t border-morska-ziel mt-8 pt-8 text-center text-mietowy">
        <p>&copy; {new Date().getFullYear()} Poradnia Dietetyczna. Wszelkie prawa zastrzeżone.</p>
      </div>
    </div>
  </footer>

  <!-- Mobile Menu Script -->
  <script>
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    
    mobileMenuButton?.addEventListener('click', () => {
      mobileMenu?.classList.toggle('hidden');
    });
  </script>
</body>
</html>